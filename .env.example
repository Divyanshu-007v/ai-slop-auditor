# ============================================================
# AI-Slop & Misinformation Auditor — Environment Variables
# ============================================================
# ALL keys below are OPTIONAL.
# The app works fully offline without any API keys.
# Copy this file to .env and fill in values you want to use.
# ============================================================

# Google Gemini API key — enables LLM-powered claim extraction
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# News API key — enables live news search in MCP evidence server
# Get one at: https://newsapi.org
NEWS_API_KEY=
